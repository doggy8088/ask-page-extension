{
  "manifest_version": 3,
  "name": "頁問 AskPage",
  "version": "0.22.14",
  "description": "使用 Gemini API、OpenAI API、Azure OpenAI API 或 OpenAI Compatible API 詢問關於目前頁面的問題",
  "permissions": [
    "storage",
    "activeTab",
    "userScripts"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "minimum_chrome_version": "135",
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/*"
      ],
      "js": [
        "lib/highlight.min.js",
        "lib/marked.min.js",
        "lib/purify.min.js",
        "content.js"
      ]
    }
  ],
  "commands": {
    "toggle-dialog": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open AskPage dialog"
    },
    "switch-provider": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "MacCtrl+Shift+S"
      },
      "description": "Switch AI provider"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "style.css",
        "lib/marked.min.js",
        "lib/purify.min.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
